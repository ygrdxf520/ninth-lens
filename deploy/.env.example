# ArcReel 默认部署环境配置（SQLite）
# 复制为 .env 后填入你的值

# ============================================================
# 认证配置 (Authentication)
# ============================================================
# 登录用户名（默认: admin）
AUTH_USERNAME=admin
# 登录密码（留空则首次启动时自动生成并回写到 .env 文件）
AUTH_PASSWORD=
# JWT 签名密钥（留空则自动生成，但重启后 token 失效需重新登录）
AUTH_TOKEN_SECRET=
# 认证总开关（默认 true）。设为 false 时跳过登录与 token 校验
AUTH_ENABLED=false

# ============================================================
# 日志配置 (Logging)
# ============================================================
# 日志级别（默认: INFO，可选: DEBUG, WARNING, ERROR）
# LOG_LEVEL=INFO
