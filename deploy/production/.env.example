# ArcReel 生产环境配置（PostgreSQL）
# 复制为 .env 后填入你的值

# ============================================================
# 认证配置 (Authentication)
# ============================================================
# 登录用户名（默认: admin）
AUTH_USERNAME=admin
# 登录密码（留空则首次启动时自动生成并回写到 .env 文件）
AUTH_PASSWORD=
# JWT 签名密钥（留空则自动生成，但重启后 token 失效需重新登录）
AUTH_TOKEN_SECRET=

# ============================================================
# PostgreSQL 配置
# ============================================================
# 数据库密码（必填，docker-compose 启动时会校验）
# 仅使用字母数字，避免 URL 特殊字符（@#/?% 等）导致 DATABASE_URL 解析失败
# 生成方法: openssl rand -hex 16
POSTGRES_PASSWORD=

# ============================================================
# 日志配置 (Logging)
# ============================================================
# 日志级别（默认: INFO，可选: DEBUG, WARNING, ERROR）
# LOG_LEVEL=INFO
